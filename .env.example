# Copy to .env and fill in. Everything here is OPTIONAL — by default odds come
# from the keyless Bovada provider and ratings from Valve VRS, so no key is needed.

# Odds provider: bovada (keyless, default) | oddspapi (needs key) | none
ODDS_PROVIDER=bovada

# Only needed if ODDS_PROVIDER=oddspapi. Free tier: 250 req/mo. https://oddspapi.io
ODDS_API_KEY=

# Liquipedia requires a descriptive User-Agent (their API policy).
LIQUIPEDIA_USER_AGENT=cs2-pickems/0.1 (contact: you@example.com)

# Monte Carlo sim counts
SIM_COUNT_QUICK=10000
SIM_COUNT_FULL=100000
