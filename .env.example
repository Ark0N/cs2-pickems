# Copy to .env and fill in. All keys are optional — the engine falls back to
# ranking-based ratings and manual odds entry when a key is missing.

# OddsPapi REST API key (free tier: 250 req/mo). https://oddspapi.io
ODDS_API_KEY=

# Which odds provider to use: oddspapi | theoddsapi | none
ODDS_PROVIDER=oddspapi

# Liquipedia requires a descriptive User-Agent (their API policy).
LIQUIPEDIA_USER_AGENT=cs2-pickems/0.1 (contact: you@example.com)

# Monte Carlo sim counts
SIM_COUNT_QUICK=10000
SIM_COUNT_FULL=100000
